  bool OnTimer()
  {
    mTickCount++;
    if(mTickCount < 3)
    {
      return true;
    }

    Window window = mApp.GetWindow();
    if(!AreAllResourcesReady(Actor(window.GetRootLayer())) && mTickCount < 30)
    {
