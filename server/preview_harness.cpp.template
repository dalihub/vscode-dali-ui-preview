                  {{BACKGROUND_COLOR}});
    return false;
  }

  void OnCaptured(Capture capture, Capture::FinishState state)
  {
    if(state == Capture::FinishState::SUCCEEDED)
    {
      Window window = mApp.GetWindow();
      ExportSceneMetadata(Actor(window.GetRootLayer()), "{{METADATA_PATH}}", PREVIEW_WIDTH, PREVIEW_HEIGHT);
      std::cout << "OK:{{OUTPUT_PATH}}" << std::endl;
