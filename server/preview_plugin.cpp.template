}
extern "C" float __PreviewAnimationDuration() // longest animation, in seconds
{
    float maxDur = 0.0f;
    for(auto& a : __PreviewAnims()) if(a) maxDur = std::max(maxDur, a.GetDuration());
    return maxDur;
}
extern "C" void __SetPreviewProgress(float p) // p in [0,1]
{
    // No re-Play: replaying re-captures the start value from the property's
    // current (possibly drifted/baked) value, which collapses the animation's
    // range. The animation is paused at its true start, so SetCurrentProgress
    // alone yields a stable, deterministic frame at p.
