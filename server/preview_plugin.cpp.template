    return anims;
}
extern "C" void __RegisterPreviewAnimation(Dali::Animation a)
{
    // Freeze immediately so the animation never runs to completion in real time —
    // a finished non-looping animation BAKEs its end values into the properties,
    // after which SetCurrentProgress can no longer scrub it. Play() in the user's
    // code already captured the correct start value; Pause() holds it.
    if(a) { a.Pause(); __PreviewAnims().push_back(a); }
}
extern "C" int __PreviewAnimationCount()
{
