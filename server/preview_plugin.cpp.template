// === Animation scrubbing support ===
// The build step injects `__RegisterPreviewAnimation(<anim>);` after each
// `<anim>.Play();` in user code, so the server can drive every animation to an
// exact normalized progress and capture a deterministic frame at that time.
static std::vector<Dali::Animation>& __PreviewAnims()
