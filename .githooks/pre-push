#!/usr/bin/env bash
#
# Pre-push verification gate.
#
# The golden screenshot tests render previews through the LOCAL docker DALi
# runtime. github-hosted CI can't render complex DALi scenes reliably (no GPU,
# software-only GL, cold shader cache), so this project verifies on push from a
# dev machine that HAS the docker runtime instead of gating on the cloud.
#
# Runs: TypeScript compile -> unit tests -> golden render suite (docker).
# A non-zero exit aborts the push.
#
# Escape hatches:
#   git push --no-verify     # skip ALL hooks (compile + unit + golden)
#   SKIP_E2E=1 git push      # run compile + unit, skip the slow golden render
#
# Enable once per clone:  git config core.hooksPath .githooks
#                         (or: npm run hooks:install)
#
set -euo pipefail

echo "[pre-push] TypeScript compile + unit tests…"
npm run compile
npm run test:unit:no-coverage

if [ "${SKIP_E2E:-}" = "1" ]; then
  echo "[pre-push] SKIP_E2E=1 → skipping the golden render suite."
else
  echo "[pre-push] golden screenshot suite (docker render)…  (set SKIP_E2E=1 to skip)"
  npm run test:e2e
  echo "[pre-push] preview compile sweep (docker)…"
  npm run verify:previews:docker
fi

echo "[pre-push] ✓ all checks passed — pushing."
