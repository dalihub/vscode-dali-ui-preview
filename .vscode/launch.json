{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            // NOTE (contributors): F5 runs the extension from THIS source checkout — NOT the
            // installed .vsix — and opens test/samples (which pins runtimeMode=docker). It is a
            // developer-only debugging workflow; end users just install the .vsix and open a
            // preview normally. Run `npm run compile` yourself after changing TypeScript.
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "${workspaceFolder}/test/samples"
            ]
        }
    ]
}
